{
  "name": "sora",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n build,uno,server -c blue,magenta,green \"bf build --watch\" \"unocss --watch\" \"wrangler dev --live-reload\"",
    "build": "bf build --minify && unocss",
    "deploy": "bf build --minify && unocss && wrangler deploy",
    "watch": "concurrently -k -n build,uno -c blue,magenta \"bf build --watch\" \"unocss --watch\"",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@barefootjs/client": "^0.26.2",
    "@barefootjs/hono": "^0.26.2",
    "@barefootjs/jsx": "^0.26.2",
    "@barefootjs/router": "^0.26.2",
    "@barefootjs/shared": "^0.26.2",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@barefootjs/cli": "^0.26.2",
    "@barefootjs/test": "^0.26.2",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@unocss/cli": "^66.0.0",
    "@unocss/preset-wind4": "^66.0.0",
    "concurrently": "^9.0.0",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.6.0",
    "unocss": "^66.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.0.0"
  }
}
